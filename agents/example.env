# Required (default configured for OpenAI)
OPENAI_API_KEY=sk-***

# Optional: Use a different model provider
# ANTHROPIC_API_KEY=sk-ant-***
# GOOGLE_API_KEY=***

# Exa API key for web research
# EXA_API_KEY=***

# NATS
# NATS_URL=nats://localhost:4222

# Knowledge ingestion
# KB_INGEST_ENABLED=true
# KB_MAX_FILE_BYTES=20971520
# KB_PULL_BATCH=20
# KB_FETCH_TIMEOUT=1.0
# KB_ACK_WAIT_SECONDS=30
# KB_CONSUMER_NAME=seraph-agents-kb
# KB_INGEST_PARALLELISM=4

# Database (defaults work out of the box)
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
